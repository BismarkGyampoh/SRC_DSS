{
  "info": {
    "name": "SRC DSS API",
    "description": "Postman Collection for SRC Decision Support System API",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost/DSS",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Authentication",
      "item": [
        {
          "name": "Admin Login",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "username",
                  "value": "admin",
                  "type": "text"
                },
                {
                  "key": "password",
                  "value": "password123",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/controllers/login_action.php",
              "host": ["{{base_url}}"],
              "path": ["controllers", "login_action.php"]
            }
          }
        }
      ]
    },
    {
      "name": "GDSS",
      "item": [
        {
          "name": "Submit Vote - Valid",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "reach_weight",
                  "value": "0.6",
                  "type": "text"
                },
                {
                  "key": "speed_weight",
                  "value": "0.4",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/controllers/action_gdss_vote.php",
              "host": ["{{base_url}}"],
              "path": ["controllers", "action_gdss_vote.php"]
            }
          }
        },
        {
          "name": "Submit Vote - Failure",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": [
                {
                  "key": "reach_weight",
                  "value": "0.8",
                  "type": "text"
                },
                {
                  "key": "speed_weight",
                  "value": "0.5",
                  "type": "text"
                }
              ]
            },
            "url": {
              "raw": "{{base_url}}/controllers/action_gdss_vote.php",
              "host": ["{{base_url}}"],
              "path": ["controllers", "action_gdss_vote.php"]
            }
          }
        },
        {
          "name": "Finalize GDSS Averages",
          "request": {
            "method": "POST",
            "header": [],
            "body": {
              "mode": "urlencoded",
              "urlencoded": []
            },
            "url": {
              "raw": "{{base_url}}/controllers/action_gdss_finalize.php",
              "host": ["{{base_url}}"],
              "path": ["controllers", "action_gdss_finalize.php"]
            }
          }
        }
      ]
    },
